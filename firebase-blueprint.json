{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Represents a student in the classroom.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the student." },
        "name": { "type": "string", "description": "Full name of the student." },
        "photoUrl": { "type": "string", "description": "URL to the student's profile photo." },
        "status": { "type": "string", "enum": ["present", "absent"], "description": "Current attendance status." }
      },
      "required": ["id", "name", "status"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Represents a single attendance event.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "ID of the student." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time the student was detected." },
        "confidence": { "type": "number", "description": "AI confidence score." }
      },
      "required": ["studentId", "timestamp"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Represents a security or behavioral alert.",
      "type": "object",
      "properties": {
        "message": { "type": "string", "description": "The alert message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time the alert was triggered." },
        "severity": { "type": "string", "enum": ["low", "medium", "high"], "description": "Alert severity level." }
      },
      "required": ["message", "timestamp", "severity"]
    }
  },
  "firestore": {
    "/students": {
      "schema": "Student",
      "description": "Collection of students."
    },
    "/attendance": {
      "schema": "AttendanceRecord",
      "description": "History of attendance detections."
    },
    "/alerts": {
      "schema": "Alert",
      "description": "Security and system alerts."
    }
  }
}
